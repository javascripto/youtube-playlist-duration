{
  "name": "youtube-playlist-duration",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-browser WebExtension starter (Chrome + Firefox)",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsx scripts/build.ts",
    "dev": "tsx scripts/build.ts --watch",
    "build:options": "vite build --config vite.options.config.ts",
    "build:popup": "vite build --config vite.popup.config.ts",
    "dev:options": "vite --config vite.options.config.ts",
    "dev:popup": "vite --config vite.popup.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "package:chrome": "tsx scripts/package.ts chrome",
    "package:firefox": "tsx scripts/package.ts firefox",
    "prepackages": "npm run build",
    "packages": "npm run package:chrome && npm run package:firefox",
    "lint": "npx @biomejs/biome lint --write",
    "format": "npx @biomejs/biome format --write",
    "check": "npx @biomejs/biome check --write",
    "prepare": "husky",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:options": "tsc -p tsconfig.options.json --noEmit",
    "typecheck:popup": "tsc -p tsconfig.popup.json --noEmit"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.3",
    "@types/chrome": "^0.1.37",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "esbuild": "^0.25.2",
    "husky": "^9.1.6",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.2.10",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,json}": [
      "biome check --write --organize-imports-enabled=true"
    ]
  }
}
